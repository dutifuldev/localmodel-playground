{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dutiful.dev/localmodel-playground/schemas/request-envelope.v1.schema.json",
  "title": "LocalModel Request Envelope",
  "type": "object",
  "required": ["schemaVersion", "apiShape", "request"],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "schemaVersion": {
      "const": 1
    },
    "apiShape": {
      "type": "string"
    },
    "endpointPresetId": {
      "type": "string"
    },
    "source": {
      "type": "object",
      "properties": {
        "fileName": {
          "type": "string"
        },
        "relativePath": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "request": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
