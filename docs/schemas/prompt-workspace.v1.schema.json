{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dutiful.dev/localmodel-playground/schemas/prompt-workspace.v1.json",
  "title": "LocalModel Prompt Workspace",
  "type": "object",
  "required": ["schemaVersion", "name", "tabs"],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "schemaVersion": {
      "const": 1
    },
    "name": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "activeTabId": {
      "type": ["string", "null"]
    },
    "tabs": {
      "type": "array",
      "items": {
        "$ref": "./playground-tab.v1.schema.json"
      }
    }
  },
  "additionalProperties": true
}

